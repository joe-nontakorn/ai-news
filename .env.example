# Google Gemini API Key
# ไปที่ https://aistudio.google.com เพื่อรับ Key ฟรี
GEMINI_API_KEY=your_gemini_api_key_here

# Discord Webhook URL
# Discord → Channel Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# NewsAPI Key (ฟรี 100 req/วัน)
# ไปที่ https://newsapi.org เพื่อสมัคร
NEWS_API_KEY=your_newsapi_key_here

# หุ้นที่ต้องการติดตาม (คั่นด้วย comma)
STOCK_SYMBOLS=NVDA,AAPL,MSFT,GOOGL,META,AMZN,TSLA,AMD,AVGO,JPM,LLY,COST

# เวลาส่งรายงาน (Cron format, ค่า default = 7:00 เช้า เวลาไทย UTC+7)
# 0 0 * * * = 7:00 AM Thailand time (00:00 UTC)
CRON_SCHEDULE=0 0 * * *

# Timezone
TZ=Asia/Bangkok
